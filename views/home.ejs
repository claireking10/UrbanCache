<%- include('../partials/head', { page_title: "Home" }) %>
    <div class="homecontainer">
        <div class="slogandiv">
            <h1>Discover the <span style="color:#4F39F6;">Underrated</span> Cities of
            the World.
            </h1>
            <p1>
                Most people only know the giants. UrbanCache puts the spotlight on vibrant, influential, but lesser known cities. Test your knowledge and explore the world beyond postcards and magnets.
            </p1>
            <div class="homeButtons">
                <a href="/trivia">
                    <button class= triviaButton>Play Trivia</button>
                </a>
                <a href="/cityExplorer">
                    <button class= explorerButton>Explore Cities</button>
                </a>
            </div>
            
        </div>
        <div class="imgdiv">
            <img class="homePhoto" id="homePhoto" src="<%= images[0] %>">
        </div>
    </div>
<%- include('../partials/foot') %>

<!-- script to make the home page image slideshow -->
<script>
    const images = JSON.parse('<%- JSON.stringify(images) %>');
    let index = 0;

    const imgElement = document.getElementById("homePhoto");

    setInterval(() => {
        index = (index + 1) % images.length;
        imgElement.src = images[index];
    }, 9000); // edit this to change speed of slideshow, is set to 9 seconds right now
</script>